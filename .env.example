HOST_RUNTIME_MODE=docker
HOST_API_TOKEN=change-me
HOST_PORT_RANGE_START=7777
HOST_PORT_RANGE_END=7977
HOST_MAX_SESSIONS=6
HOST_DOCKER_IMAGE=ghcr.io/your-org/andromeda-eob-host:latest
HOST_DOCKER_CONTAINER_PREFIX=andromeda-eob
# Leave empty to use the image ENTRYPOINT.
HOST_DOCKER_ENTRYPOINT=
# Optional persistent host path mounted to /data inside spawned game containers.
HOST_DOCKER_DATA_ROOT=/var/lib/andromeda-eob
# For process mode only
HOST_GAME_EXECUTABLE_PATH=/opt/eob/enemy-on-board.exe
