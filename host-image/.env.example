# Required for runtime.py docker mode
HOST_DOCKER_IMAGE=ghcr.io/your-org/andromeda-eob-host:latest

# SteamCMD/Game provisioning
EOB_APP_ID=999860
EOB_AUTO_UPDATE=1
EOB_VALIDATE=0
EOB_EXE_RELATIVE_PATH=enemy-on-board.exe

# SteamCMD/Game provisioning
EOB_APP_ID=999860
EOB_AUTO_UPDATE=1
EOB_VALIDATE=0
EOB_EXE_RELATIVE_PATH=enemy-on-board.exe

# Steam authentication - Two methods supported:
#
# Method 1: Cached login (RECOMMENDED)
# Set STEAM_USER to your account, leave STEAM_PASS empty to use cached credentials.
# You must first run steamcmd interactively once to cache login:
#   docker run -it -v steam-cache:/home/andromeda/.steam <image> \
#     /opt/andromeda/install_steamcmd.sh
# Then manually: steamcmd +login YOUR_USER (enter password + guard code when prompted)
# After that, STEAM_PASS=empty works since Docker reuses the cached token.
#
# Method 2: Direct credentials (one-time setup)
# Provide STEAM_USER and STEAM_PASS with STEAM_AUTH_CODE/STEAM_GUARD_CODE if needed.
# WARNING: This will re-authenticate every container run, triggering Steam Guard.
#
# Method 3: Anonymous (default, free-to-play only)
# Leave STEAM_USER as "anonymous" - can only download free-to-play dedicated server files.

STEAM_USER=anonymous
STEAM_PASS=
STEAM_AUTH_CODE=
STEAM_GUARD_CODE=
STEAM_BRANCH=
STEAM_BRANCH_PASSWORD=

# MelonLoader/Mod automation (optional)
MELONLOADER_URL=
MELONLOADER_VERSION=
ANDROMEDA_MOD_URL=
ANDROMEDA_MOD_VERSION=

# Persistent mount points inside container
STEAMCMD_DIR=/opt/steamcmd
GAME_DIR=/data/game
WINEPREFIX=/data/wineprefix
MELONLOADER_DIR=/data/melonloader
MODS_DIR=/data/mods
