# Required for runtime.py docker mode
HOST_DOCKER_IMAGE=ghcr.io/your-org/andromeda-eob-host:latest

# SteamCMD/Game provisioning
EOB_APP_ID=999860
EOB_AUTO_UPDATE=1
EOB_VALIDATE=0
EOB_EXE_RELATIVE_PATH=enemy-on-board.exe

# Steam auth. Leave empty for anonymous attempts.
STEAM_USER=anonymous
STEAM_PASS=
STEAM_AUTH_CODE=
STEAM_GUARD_CODE=
STEAM_BRANCH=
STEAM_BRANCH_PASSWORD=

# MelonLoader/Mod automation (optional)
MELONLOADER_URL=
MELONLOADER_VERSION=
ANDROMEDA_MOD_URL=
ANDROMEDA_MOD_VERSION=

# Persistent mount points inside container
STEAMCMD_DIR=/opt/steamcmd
GAME_DIR=/data/game
WINEPREFIX=/data/wineprefix
MELONLOADER_DIR=/data/melonloader
MODS_DIR=/data/mods
